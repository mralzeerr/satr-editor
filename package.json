{
  "name": "satr",
  "productName": "Satr",
  "version": "1.5.1",
  "description": "سطر (Satr) — وكيل برمجي عربي يبني تطبيقاتك بالكامل بالذكاء الاصطناعي",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.aetiger.satr",
    "productName": "Satr",
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "mralzeerr",
      "repo": "satr-editor"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!gen-icon.js",
      "!icon.png",
      "!node_modules/monaco-editor/esm/**",
      "!node_modules/monaco-editor/dev/**",
      "!node_modules/monaco-editor/min-maps/**",
      "!node_modules/prettier/plugins/{acorn,angular,flow,glimmer,graphql,meriyah,yaml}.*",
      "!node_modules/typescript/**"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.ico"
    },
    "portable": {
      "artifactName": "Satr-${version}-portable.exe"
    },
    "nsis": {
      "artifactName": "Satr-Setup-${version}.exe",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "سطر",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "author": "aetiger",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@fontsource/ibm-plex-sans-arabic": "^5.3.0",
    "@sentry/electron": "^7.15.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.8.9",
    "monaco-editor": "^0.52.0",
    "prettier": "^3.9.5"
  }
}
